{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5005",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__MasterConnection": "Host=127.0.0.1;Port=5432;Database=otus_db;Username=postgres;Password=my_pass",
        "ConnectionStrings__SlaveConnections": "Host=127.0.0.1;Port=5433;Database=otus_db;Username=postgres;Password=my_pass;Host=127.0.0.1;Port=5434;Database=otus_db;Username=postgres;Password=my_pass"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7282;http://localhost:5005",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__MasterConnection": "Host=127.0.0.1;Port=5432;Database=otus_db;Username=postgres;Password=my_pass;SSL Mode=Disable;Trust Server Certificate=true;",
        "ConnectionStrings__SlaveConnections": "Host=127.0.0.1;Port=5433;Database=otus_db;Username=postgres;Password=my_pass;SSL Mode=Disable;Trust Server Certificate=true;|Host=127.0.0.1;Port=5434;Database=otus_db;Username=postgres;Password=my_pass;SSL Mode=Disable;Trust Server Certificate=true;"
      }
    }
  }
}
